  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  returnItems ReturnItem[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([orderId])
  @@index([status])
  @@map("returns")
}

model ReturnItem {
