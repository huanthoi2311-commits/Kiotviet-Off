  minQuantity   Int?
  minAmount     Decimal?               @db.Decimal(18, 2)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([promotionId])
  @@map("promotion_conditions")
}

model Voucher {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  code           String
  type           VoucherType
  value          Decimal       @db.Decimal(18, 2)
  minOrderAmount Decimal?      @db.Decimal(18, 2)
  maxDiscount    Decimal?      @db.Decimal(18, 2)
  usageLimit     Int?
  usedCount      Int           @default(0)
  startDate      DateTime
  endDate        DateTime
  status         VoucherStatus @default(ACTIVE)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("vouchers")
}

// =========================================================================
// FULFILLMENT
// =========================================================================

model Delivery {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  orderId        String       @unique @db.Uuid
  order          Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  code           String
  status         DeliveryStatus @default(PENDING)
  recipientName  String
  recipientPhone String
  address        String
  fee            Decimal        @default(0) @db.Decimal(18, 2)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  shipments Shipment[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([status])
  @@map("deliveries")
}

model Shipment {
  id         String   @id @default(uuid()) @db.Uuid
  deliveryId String   @db.Uuid
  delivery   Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  carrier        String?
  trackingNumber String?
  status         ShipmentStatus @default(CREATED)
  shippedAt      DateTime?
  deliveredAt    DateTime?

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deliveryId])
  @@index([trackingNumber])
  @@map("shipments")
}

// =========================================================================
// PLATFORM (SHARED KERNEL)
// =========================================================================

model Notification {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  userId         String?      @db.Uuid
  user           User?        @relation(fields: [userId], references: [id], onDelete: Cascade)

  title   String
  content String
  type    String?
  channel NotificationChannel @default(IN_APP)
  isRead  Boolean             @default(false)
  readAt  DateTime?

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([organizationId])
  @@index([userId, isRead])
  @@map("notifications")
}

model File {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  uploadedBy     String?      @db.Uuid
  uploadedByUser User?        @relation(fields: [uploadedBy], references: [id], onDelete: SetNull)

  ownerType String?
  ownerId   String? @db.Uuid
  fileName  String
  filePath  String
  mimeType  String
  size      Int

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([organizationId])
  @@index([ownerType, ownerId])
  @@map("files")
}

model Webhook {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  url             String
  event           String
  secret          String
  isActive        Boolean   @default(true)
  lastTriggeredAt DateTime?

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  logs WebhookLog[]

  @@index([organizationId])
  @@index([event])
  @@map("webhooks")
}

model WebhookLog {
  id        String  @id @default(uuid()) @db.Uuid
  webhookId String  @db.Uuid
  webhook   Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  event          String
  payload        Json
  responseStatus Int?
  success        Boolean @default(false)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([webhookId])
  @@map("webhook_logs")
}

model ApiKey {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  name       String
  keyHash    String    @unique
  scopes     String[]
  lastUsedAt DateTime?
  expiresAt  DateTime?

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([organizationId])
  @@map("api_keys")
}
