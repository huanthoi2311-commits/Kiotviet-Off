// POS ERP Enterprise v1.0 — Prisma Schema
// Sinh từ: docs/architecture/002-database-erd.md (Prompt 003)
//
// Quy ước:
// - Mọi model kế thừa Base Audit Fields: createdBy, updatedBy, createdAt, updatedAt, deletedAt (soft delete).
// - createdBy/updatedBy là scalar UUID KHÔNG khai báo relation() tới User để tránh bùng nổ quan hệ
//   (mỗi model sẽ cần 2 back-relation trên User cho mỗi bảng => không khả thi ở quy mô 46 bảng).
//   Toàn vẹn dữ liệu cho 2 cột này được đảm bảo ở tầng Application (luôn set từ TenantContext/RequestUser).
// - organizationId là ranh giới tenant bắt buộc trên mọi bảng nghiệp vụ (trừ Organization, Permission).
// - Toàn bộ enum đặt UPPER_SNAKE_CASE theo chuẩn Prisma.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================================================================
// ENUMS
// =========================================================================

enum OrganizationPlan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  /// Đổi tên từ CANCELLED (SPEC-ORG-001 Decision 2) — trạng thái nghiệp vụ, khác với
  /// `deletedAt` (cơ chế soft-delete kỹ thuật, vẫn giữ song song).
  ARCHIVED
}

enum OrganizationSubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum CommonStatus {
  ACTIVE
  INACTIVE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum CustomerType {
  RETAIL
  WHOLESALE
  VIP
  DEALER
  COMPANY
}

enum ProductStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ProductType {
  STANDARD
  SERVICE
  VARIANT_PARENT
  VARIANT_CHILD
}

enum PriceType {
  COST
  SELLING
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING
  APPROVED
  RECEIVED
  COMPLETED
  CANCELLED
}

enum OrderType {
  POS
  ONLINE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  RETURNED
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
  CANCELLED
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}

enum DebtType {
  RECEIVABLE
  PAYABLE
}

enum DebtStatus {
  OPEN
  PARTIAL
  SETTLED
  OVERDUE
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  E_WALLET
}

enum PaymentDirection {
  IN
  OUT
}

enum CashBookType {
  RECEIPT
  PAYMENT
}

enum PromotionType {
  PERCENTAGE
  FIXED_AMOUNT
  GIFT
}

enum ApplyScope {
  ALL
  CATEGORY
  PRODUCT
}

enum PromotionConditionType {
  CATEGORY
  PRODUCT
  MIN_AMOUNT
  MIN_QUANTITY
}

enum PromotionStatus {
  ACTIVE
  INACTIVE
  EXPIRED
}

enum VoucherType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum VoucherStatus {
  ACTIVE
  INACTIVE
  EXPIRED
}

enum DeliveryStatus {
  PENDING
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
  RETURNED
}

enum ShipmentStatus {
  CREATED
  SHIPPING
  DELIVERED
  FAILED
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
}

enum SessionClientType {
  WEB
  MOBILE
}

// =========================================================================
// IDENTITY & ACCESS + ORGANIZATION
// =========================================================================

/// Root Aggregate (SPEC-ORG-001). Không module nào được ghi trực tiếp vào OrganizationSettings/
/// OrganizationSubscription — chỉ qua module `organization`.
model Organization {
  id           String             @id @default(uuid()) @db.Uuid
  /// Sinh tự động (ORG000001), không cho sửa (SPEC-ORG-001 Rule 7).
  code         String             @unique
  displayName  String
  legalName    String?
  /// Không cho sửa sau khi tạo (SPEC-ORG-001 Rule 6).
  slug         String             @unique
  taxCode      String?            @unique
  email        String?            @unique
  phone        String?
  website      String?
  logoUrl      String?
  address      String?
  province     String?
  district     String?
  ward         String?
  countryCode  String             @default("VN")
  /// Timezone chuẩn IANA (vd: Asia/Ho_Chi_Minh) — validate ở application layer.
  timezone     String             @default("Asia/Ho_Chi_Minh")
  /// ISO 4217 (vd: VND) — validate ở application layer.
  currencyCode String             @default("VND")
  languageCode String             @default("vi")
  status       OrganizationStatus @default(ACTIVE)
  /// Nullable ở schema vì User.organizationId bắt buộc NOT NULL — transaction tạo Organization
  /// phải tạo Organization trước (ownerUserId tạm null), tạo Owner User, rồi UPDATE lại field
  /// này (SPEC-ORG-001 Decision 3). Ở tầng nghiệp vụ, sau khi tạo xong KHÔNG bao giờ còn null.
  ownerUserId  String?            @unique @db.Uuid
  owner        User?              @relation("OrganizationOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  /// @deprecated Dùng OrganizationSubscription.plan làm Single Source of Truth (SPEC-ORG-001
  /// Decision 1). Giữ cột này tạm thời để tương thích ngược, sẽ gỡ bỏ ở migration sau — KHÔNG
  /// đọc/ghi field này ở logic mới.
  plan         OrganizationPlan   @default(FREE)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  organizationSettings OrganizationSettings?
  subscription         OrganizationSubscription?
  branches             Branch[]
  warehouses           Warehouse[]
  users                User[]
  roles                Role[]
  settings             Setting[]
  categories           Category[]
  brands               Brand[]
  units                Unit[]
  taxes                Tax[]
  products             Product[]
  barcodes             Barcode[]
  suppliers            Supplier[]
  purchaseOrders       PurchaseOrder[]
  purchaseReturns      PurchaseReturn[]
  orders               Order[]
  invoices             Invoice[]
  returns              Return[]
  customerGroups       CustomerGroup[]
  customers            Customer[]
  debts                Debt[]
  pointLedgers         CustomerPointLedger[]
  payments             Payment[]
  cashBooks            CashBook[]
  expenseCategories    ExpenseCategory[]
  expenses             Expense[]
  promotions           Promotion[]
  vouchers             Voucher[]
  deliveries           Delivery[]
  notifications        Notification[]
  files                File[]
  webhooks             Webhook[]
  apiKeys              ApiKey[]
  auditLogs            AuditLog[]
  inventories          Inventory[]
  inventoryMovements   InventoryMovement[]
  transfers            Transfer[]
  stockCounts          StockCount[]
  inventoryAdjustments InventoryAdjustment[]
  sequences            Sequence[]

  @@map("organizations")
}

/// Business Setting theo Organization (SPEC-ORG-001 §8) — KHÁC với `Setting` (Platform Setting
/// dùng chung, vd SMTP/Redis/Storage, SPEC-ORG-001 Decision 6). Không migrate module Inventory
/// sang đọc bảng này ở Sprint-00 — để dành Sprint-05 (Inventory Review).
model OrganizationSettings {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @unique @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  allowNegativeInventory Boolean    @default(false)
  allowBackDate          Boolean    @default(false)
  decimalQuantity        Int        @default(0)
  decimalPrice           Int        @default(0)
  defaultWarehouseId     String?    @db.Uuid
  defaultWarehouse       Warehouse? @relation(fields: [defaultWarehouseId], references: [id], onDelete: SetNull)
  defaultBranchId        String?    @db.Uuid
  defaultBranch          Branch?    @relation("OrganizationDefaultBranch", fields: [defaultBranchId], references: [id], onDelete: SetNull)
  defaultLanguage        String     @default("vi")
  defaultCurrency        String     @default("VND")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("organization_settings")
}

/// Chỉ tạo cấu trúc — không triển khai logic thanh toán/billing ở Sprint-00 (SPEC-ORG-001 §9).
/// Single Source of Truth cho `plan` — xem `Organization.plan` (deprecated).
model OrganizationSubscription {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @unique @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  plan           OrganizationPlan               @default(FREE)
  status         OrganizationSubscriptionStatus @default(ACTIVE)
  startedAt      DateTime                       @default(now())
  expiredAt      DateTime?
  maxBranch      Int?
  maxUser        Int?
  maxWarehouse   Int?
  maxProduct     Int?
  maxCustomer    Int?
  storageLimitGB Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("organization_subscriptions")
}

/// SPEC-BRANCH-001. `isMain` = "Branch mặc định" (chỉ 1 cái/Organization — set qua
/// POST /branches/:id/set-default, không phải field literal trong spec nhưng khớp đúng
/// nghĩa "Chỉ một Branch mặc định cho mỗi Organization" — giữ nguyên tên field có sẵn).
model Branch {
  id                 String       @id @default(uuid()) @db.Uuid
  organizationId     String       @db.Uuid
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  managerUserId      String?      @db.Uuid
  manager            User?        @relation("BranchManager", fields: [managerUserId], references: [id], onDelete: SetNull)
  /// Nullable — Branch có thể chưa có Warehouse mặc định ngay lúc tạo (Warehouse phải tạo sau,
  /// vì Warehouse.branchId bắt buộc NOT NULL, cùng lý do bootstrap như Organization.ownerUserId).
  defaultWarehouseId String?      @db.Uuid
  defaultWarehouse   Warehouse?   @relation("BranchDefaultWarehouse", fields: [defaultWarehouseId], references: [id], onDelete: SetNull)

  /// Sinh tự động (BR000001).
  code          String
  name          String
  email         String?
  address       String?
  province      String?
  district      String?
  ward          String?
  phone         String?
  /// Unique trong Organization (SPEC-BRANCH-001 §4).
  invoicePrefix String?
  receiptPrefix String?
  timezone      String       @default("Asia/Ho_Chi_Minh")
  currencyCode  String       @default("VND")
  isMain        Boolean      @default(false)
  status        BranchStatus @default(ACTIVE)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  warehouses            Warehouse[]
  users                 User[]
  settings              Setting[]
  purchaseOrders        PurchaseOrder[]
  orders                Order[]
  invoices              Invoice[]
  payments              Payment[]
  cashBooks             CashBook[]
  expenses              Expense[]
  promotions            Promotion[]
  organizationDefaultOf OrganizationSettings[] @relation("OrganizationDefaultBranch")

  @@unique([organizationId, code])
  @@unique([organizationId, invoicePrefix])
  @@index([organizationId])
  @@map("branches")
}

enum BranchStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum WarehouseType {
  MAIN
  RETAIL
  ONLINE
  RETURN
  DAMAGED
  TRANSIT
  CUSTOM
}

model Warehouse {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branchId       String       @db.Uuid
  branch         Branch       @relation(fields: [branchId], references: [id], onDelete: Restrict)
  managerId      String?      @db.Uuid
  manager        User?        @relation(fields: [managerId], references: [id], onDelete: SetNull)

  code        String
  name        String
  type        WarehouseType @default(MAIN)
  address     String?
  phone       String?
  email       String?
  description String?
  status      CommonStatus  @default(ACTIVE)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  purchaseItems                 PurchaseItem[]
  purchaseReturnItems           PurchaseReturnItem[]
  orders                        Order[]
  inventories                   Inventory[]
  inventoryMovements            InventoryMovement[]
  transfersFrom                 Transfer[]             @relation("TransferFromWarehouse")
  transfersTo                   Transfer[]             @relation("TransferToWarehouse")
  stockCounts                   StockCount[]
  inventoryAdjustments          InventoryAdjustment[]
  organizationSettingsDefaultOf OrganizationSettings[]
  branchDefaultOf               Branch[]               @relation("BranchDefaultWarehouse")

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([branchId])
  @@index([managerId])
  @@map("warehouses")
}

model Setting {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branchId       String?      @db.Uuid
  branch         Branch?      @relation(fields: [branchId], references: [id], onDelete: Cascade)

  key      String
  value    Json
  category String?

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([organizationId, branchId, key])
  @@index([organizationId])
  @@index([category])
  @@map("settings")
}

model User {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branchId       String?      @db.Uuid
  branch         Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)

  username          String
  fullName          String?
  email             String
  phone             String?
  passwordHash      String
  avatar            String?
  status            UserStatus @default(ACTIVE)
  lastLoginAt       DateTime?
  /// Tăng lên mỗi khi role/permission của user thay đổi — nhúng vào JWT để
  /// buộc access token cũ (còn hạn nhưng quyền đã lỗi thời) phải đăng nhập lại.
  permissionVersion Int        @default(1)
  /// Không gắn với Role/Organization nào — chỉ user này mới được gọi POST /organizations
  /// (SPEC-ORG-001 Decision 4: không thêm Global Role, không sửa RBAC hiện tại).
  isPlatformAdmin   Boolean    @default(false)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  userRoles         UserRole[]
  sessions          Session[]
  notifications     Notification[]
  uploadedFiles     File[]
  auditLogs         AuditLog[]
  ordersSold        Order[]        @relation("OrderSoldBy")
  returnsProcessed  Return[]       @relation("ReturnProcessedBy")
  priceChanges      PriceHistory[] @relation("PriceHistoryChangedBy")
  paymentsReceived  Payment[]      @relation("PaymentReceivedBy")
  managedWarehouses Warehouse[]
  managedBranches   Branch[]       @relation("BranchManager")
  ownedOrganization Organization?  @relation("OrganizationOwner")

  @@unique([organizationId, username])
  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([branchId])
  @@map("users")
}

model Role {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  code        String
  name        String
  isSystem    Boolean @default(false)
  description String?

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid()) @db.Uuid
  code        String  @unique
  group       String
  description String?

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  rolePermissions RolePermission[]

  @@index([group])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid()) @db.Uuid
  roleId       String     @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String     @db.Uuid
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId String @db.Uuid
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

/// Một phiên đăng nhập = một thiết bị. Refresh token là "vé" của phiên đó;
/// các cột thiết bị/địa lý phục vụ UI "Quản lý phiên đăng nhập" kiểu Google.
model Session {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshTokenHash String            @unique
  deviceName       String?
  browser          String?
  os               String?
  clientType       SessionClientType @default(WEB)
  ip               String?
  country          String?
  city             String?
  expiresAt        DateTime
  revokedAt        DateTime?
  lastActivityAt   DateTime?

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model AuditLog {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  userId         String?      @db.Uuid
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  action     String
  entityType String
  entityId   String? @db.Uuid
  oldValue   Json?
  newValue   Json?
  ip         String?
  userAgent  String?
  /// X-Request-ID của request gây ra thay đổi — nối log ứng dụng với bản ghi audit.
  traceId    String?

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([organizationId])
  @@index([userId])
  @@index([organizationId, entityType, entityId])
  @@map("audit_logs")
}

// =========================================================================
// CATALOG
// =========================================================================

model Category {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  parentId       String?      @db.Uuid
  parent         Category?    @relation("CategoryParent", fields: [parentId], references: [id], onDelete: SetNull)

  code        String
  name        String
  slug        String
  description String?
  imageUrl    String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  children Category[] @relation("CategoryParent")
  products Product[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([parentId])
  @@map("categories")
}

model Brand {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  code        String
  name        String
  logo        String?
  description String?
  website     String?
  country     String?
  status      CommonStatus @default(ACTIVE)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  products Product[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("brands")
}

model Unit {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  code   String
  name   String
  symbol String

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  products Product[]
  barcodes Barcode[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("units")
}

model Tax {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  code      String
  name      String
  rate      Decimal      @db.Decimal(5, 2)
  isDefault Boolean      @default(false)
  status    CommonStatus @default(ACTIVE)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("taxes")
}

model Product {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  categoryId     String       @db.Uuid
  category       Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  brandId        String?      @db.Uuid
  brand          Brand?       @relation(fields: [brandId], references: [id], onDelete: SetNull)
  unitId         String       @db.Uuid
  unit           Unit         @relation(fields: [unitId], references: [id], onDelete: Restrict)

  /// Self-reference cho Variant Child -> Variant Parent (Decision 9, SPEC-PRODUCT-001 §3.3).
  /// Variant Child la 1 Product binh thuong (type=VARIANT_CHILD), khong tao model Variant rieng.
  parentProductId String?   @db.Uuid
  parent          Product?  @relation("ProductVariants", fields: [parentProductId], references: [id], onDelete: Restrict)
  variants        Product[] @relation("ProductVariants")

  sku         String
  slug        String
  name        String
  description String?
  costPrice   Decimal       @db.Decimal(18, 2)
  /// % thuế GTGT áp cho sản phẩm (VD: 8.00, 10.00) — snapshot đơn giản, không phải FK tới Tax.
  vat         Decimal       @default(0) @db.Decimal(5, 2)
  weight      Decimal?      @db.Decimal(18, 3)
  length      Decimal?      @db.Decimal(18, 3)
  width       Decimal?      @db.Decimal(18, 3)
  height      Decimal?      @db.Decimal(18, 3)
  minStock    Decimal?      @db.Decimal(18, 3)
  maxStock    Decimal?      @db.Decimal(18, 3)
  /// Phan loai san pham - thay the `isService` (Decision 5, SPEC-PRODUCT-001 §1.1/§3.2). Khong
  /// con DEFAULT tu Migration 3 - code luon phai truyen tuong minh.
  type        ProductType
  allowSale   Boolean       @default(true)
  /// Trạng thái vòng đời (DRAFT/ACTIVE/INACTIVE/ARCHIVED — Decision 3).
  status      ProductStatus @default(ACTIVE)
  /// Bật/tắt nhanh không đổi vòng đời — VD: tạm ẩn khỏi POS mà không đổi status.
  isActive    Boolean       @default(true)
  /// Optimistic Lock (Decision A02) - tang o moi UPDATE, khong bao gio reset (Decision A09).
  version     Int           @default(1)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  prices                   ProductPrice[]
  images                   ProductImage[]
  barcodes                 Barcode[]
  priceHistories           PriceHistory[]
  inventories              Inventory[]
  inventoryMovements       InventoryMovement[]
  purchaseItems            PurchaseItem[]
  purchaseReturnItems      PurchaseReturnItem[]
  orderItems               OrderItem[]
  returnItems              ReturnItem[]
  transferItems            TransferItem[]
  stockCountItems          StockCountItem[]
  inventoryAdjustmentItems InventoryAdjustmentItem[]
  supplierProducts         SupplierProduct[]
  invoiceItems             InvoiceItem[]

  @@unique([organizationId, sku])
  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([categoryId])
  @@index([brandId])
  @@index([name])
  @@index([parentProductId])
  @@map("products")
}

enum ProductPriceType {
  RETAIL
  WHOLESALE
  VIP
  DEALER
}

/// Giá bán tách khỏi Product — 1 product có nhiều mức giá theo nhóm khách hàng,
/// không hard-code sellingPrice vào Product (Prompt 016).
model ProductPrice {
  id        String  @id @default(uuid()) @db.Uuid
  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  type  ProductPriceType
  price Decimal          @db.Decimal(18, 2)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([productId, type])
  @@index([productId])
  @@map("product_prices")
}

/// Nhiều hình ảnh/sản phẩm — không lưu image trong Product (Prompt 016).
model ProductImage {
  id        String  @id @default(uuid()) @db.Uuid
  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  url         String
  sortOrder   Int     @default(0)
  isThumbnail Boolean @default(false)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([productId])
  @@map("product_images")
}

/// Counter nguyên tử theo Organization, dùng sinh SKU tự động (SP000001, SP000002...).
model Sequence {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  name  String
  value Int    @default(0)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([organizationId, name])
  @@map("sequences")
}

enum BarcodeType {
  EAN13
  EAN8
  CODE128
  QR
  CUSTOM
}

model Barcode {
  id             String       @id @default(uuid()) @db.Uuid
  productId      String       @db.Uuid
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  unitId         String?      @db.Uuid
  unit           Unit?        @relation(fields: [unitId], references: [id], onDelete: SetNull)
  /// Denormalize tu Product.organizationId (SPEC-PRODUCT-001 §3.4) - can truc tiep tren Barcode
  /// de tao duoc unique constraint theo tenant, khong phai suy ra gian tiep qua productId.
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  /// Unique theo tenant qua @@unique([organizationId, code]) ben duoi, khong con unique toan
  /// cuc (Decision 7 - constraint cu da bi drop o Migration 3).
  code      String
  type      BarcodeType @default(CUSTOM)
  isDefault Boolean     @default(false)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([organizationId, code])
  @@index([productId])
  @@index([organizationId])
  @@map("barcodes")
}

model PriceHistory {
  id        String  @id @default(uuid()) @db.Uuid
  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  priceType     PriceType
  oldPrice      Decimal   @db.Decimal(18, 2)
  newPrice      Decimal   @db.Decimal(18, 2)
  changedBy     String?   @db.Uuid
  changedByUser User?     @relation("PriceHistoryChangedBy", fields: [changedBy], references: [id], onDelete: SetNull)
  reason        String?

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([productId])
  @@map("price_histories")
}

// =========================================================================
// INVENTORY
// =========================================================================

model Inventory {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  warehouseId    String       @db.Uuid
  warehouse      Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  productId      String       @db.Uuid
  product        Product      @relation(fields: [productId], references: [id], onDelete: Restrict)

  /// Snapshot đọc nhanh — KHÔNG được ghi trực tiếp, chỉ được cập nhật bởi
  /// InventoryRepository.recordMovement() trong cùng transaction với InventoryMovement.
  quantity    Decimal @default(0) @db.Decimal(18, 3)
  reservedQty Decimal @default(0) @db.Decimal(18, 3)
  avgCost     Decimal @default(0) @db.Decimal(18, 2)
  lastCost    Decimal @default(0) @db.Decimal(18, 2)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([warehouseId, productId])
  @@index([organizationId])
  @@map("inventories")
}

enum InventoryMovementType {
  PURCHASE
  SALE
  RETURN
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT
  COUNT
  DAMAGE
  INITIAL
}

enum InventoryReferenceType {
  PURCHASE
  POS
  TRANSFER
  COUNT
  RETURN
  SYSTEM
}

/// Ledger bất biến (append-only) — nguồn sự thật (Source of Truth) cho mọi biến động
/// tồn kho. Không có updatedAt/deletedAt: một dòng Movement không bao giờ được sửa
/// hay xóa sau khi ghi — sai sót được sửa bằng một Movement bù trừ mới, không sửa dòng cũ.
model InventoryMovement {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  warehouseId    String       @db.Uuid
  warehouse      Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  productId      String       @db.Uuid
  product        Product      @relation(fields: [productId], references: [id], onDelete: Restrict)

  movementType   InventoryMovementType
  referenceType  InventoryReferenceType
  referenceId    String?                @db.Uuid
  /// Delta có dấu áp dụng lên quantity (dương = nhập, âm = xuất).
  quantity       Decimal                @db.Decimal(18, 3)
  beforeQuantity Decimal                @db.Decimal(18, 3)
  afterQuantity  Decimal                @db.Decimal(18, 3)
  unitCost       Decimal?               @db.Decimal(18, 2)
  remark         String?

  createdBy String?  @db.Uuid
  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([warehouseId])
  @@index([productId, createdAt])
  @@index([referenceType, referenceId])
  @@map("inventory_movements")
}

// =========================================================================
// PROCUREMENT
// =========================================================================

model Supplier {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  code        String
  taxCode     String?
  companyName String
  contactName String?
  phone       String?
  email       String?
  website     String?
  address     String?
  province    String?
  district    String?
  ward        String?
  bankName    String?
  bankAccount String?
  /// Số ngày công nợ cho phép (vd: 30 = NET 30).
  paymentTerm Int?
  creditLimit Decimal?     @db.Decimal(18, 2)
  status      CommonStatus @default(ACTIVE)
  note        String?

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  purchaseOrders   PurchaseOrder[]
  purchaseReturns  PurchaseReturn[]
  debts            Debt[]
  payments         Payment[]
  supplierProducts SupplierProduct[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("suppliers")
}

model SupplierProduct {
  id         String   @id @default(uuid()) @db.Uuid
  supplierId String   @db.Uuid
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  productId  String   @db.Uuid
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  supplierSku          String?
  /// Thứ tự ưu tiên chọn NCC khi 1 sản phẩm có nhiều NCC (số nhỏ hơn = ưu tiên hơn).
  priority             Int?     @default(0)
  defaultPrice         Decimal? @db.Decimal(18, 2)
  /// Số ngày giao hàng dự kiến kể từ khi đặt.
  leadTime             Int?
  minimumOrderQuantity Decimal? @db.Decimal(18, 3)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([supplierId, productId])
  @@index([supplierId])
  @@index([productId])
  @@map("supplier_products")
}

model PurchaseOrder {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branchId       String       @db.Uuid
  branch         Branch       @relation(fields: [branchId], references: [id], onDelete: Restrict)
  supplierId     String       @db.Uuid
  supplier       Supplier     @relation(fields: [supplierId], references: [id], onDelete: Restrict)

  code        String
  status      PurchaseOrderStatus @default(DRAFT)
  totalAmount Decimal             @default(0) @db.Decimal(18, 2)
  paidAmount  Decimal             @default(0) @db.Decimal(18, 2)
  expectedAt  DateTime?

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  purchaseItems   PurchaseItem[]
  purchaseReturns PurchaseReturn[]
  payments        Payment[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([supplierId])
  @@index([status])
  /// Phục vụ Purchase Report (Prompt 030): lọc theo tổ chức + trạng thái đã nhận rồi
  /// group theo tháng/khoảng ngày — join order cho query planner đúng thứ tự lọc.
  @@index([organizationId, status, createdAt])
  @@map("purchase_orders")
}

model PurchaseItem {
  id              String        @id @default(uuid()) @db.Uuid
  purchaseOrderId String        @db.Uuid
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String        @db.Uuid
  product         Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  /// Mỗi dòng hàng có thể nhập vào kho khác nhau (1 đơn nhập từ 1 NCC có thể chia về nhiều kho).
  warehouseId     String        @db.Uuid
  warehouse       Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  quantity         Decimal @db.Decimal(18, 3)
  receivedQuantity Decimal @default(0) @db.Decimal(18, 3)
  unitCost         Decimal @db.Decimal(18, 2)
  discount         Decimal @default(0) @db.Decimal(18, 2)
  taxAmount        Decimal @default(0) @db.Decimal(18, 2)
  totalAmount      Decimal @default(0) @db.Decimal(18, 2)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  purchaseReturnItems PurchaseReturnItem[]

  @@index([purchaseOrderId])
  @@index([productId])
  @@index([warehouseId])
  @@map("purchase_items")
}

enum PurchaseReturnStatus {
  DRAFT
  APPROVED
  COMPLETED
  CANCELLED
}

enum PurchaseReturnReason {
  DAMAGED
  WRONG_PRODUCT
  EXPIRED
  OTHER
}

model PurchaseReturn {
  id              String        @id @default(uuid()) @db.Uuid
  organizationId  String        @db.Uuid
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  purchaseOrderId String        @db.Uuid
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Restrict)
  supplierId      String        @db.Uuid
  supplier        Supplier      @relation(fields: [supplierId], references: [id], onDelete: Restrict)

  code        String
  status      PurchaseReturnStatus @default(DRAFT)
  reason      PurchaseReturnReason
  totalAmount Decimal              @default(0) @db.Decimal(18, 2)
  note        String?

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  items PurchaseReturnItem[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([purchaseOrderId])
  @@index([supplierId])
  @@index([status])
  @@map("purchase_returns")
}

/// Mỗi dòng gắn với đúng 1 PurchaseItem gốc (không chỉ Product) để biết chính xác đã
/// nhập vào Kho nào và với Đơn giá nào — Inventory Out phải trừ đúng Kho, Debt Reduce
/// phải tính đúng theo giá vốn gốc của lần nhập đó.
model PurchaseReturnItem {
  id               String         @id @default(uuid()) @db.Uuid
  purchaseReturnId String         @db.Uuid
  purchaseReturn   PurchaseReturn @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)
  purchaseItemId   String         @db.Uuid
  purchaseItem     PurchaseItem   @relation(fields: [purchaseItemId], references: [id], onDelete: Restrict)
  productId        String         @db.Uuid
  product          Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  warehouseId      String         @db.Uuid
  warehouse        Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  quantity    Decimal @db.Decimal(18, 3)
  unitCost    Decimal @db.Decimal(18, 2)
  totalAmount Decimal @default(0) @db.Decimal(18, 2)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([purchaseReturnId])
  @@index([purchaseItemId])
  @@index([productId])
  @@index([warehouseId])
  @@map("purchase_return_items")
}

enum TransferStatus {
  DRAFT
  PENDING
  APPROVED
  SHIPPING
  RECEIVED
  CANCELLED
}

model Transfer {
  id              String       @id @default(uuid()) @db.Uuid
  organizationId  String       @db.Uuid
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  fromWarehouseId String       @db.Uuid
  fromWarehouse   Warehouse    @relation("TransferFromWarehouse", fields: [fromWarehouseId], references: [id], onDelete: Restrict)
  toWarehouseId   String       @db.Uuid
  toWarehouse     Warehouse    @relation("TransferToWarehouse", fields: [toWarehouseId], references: [id], onDelete: Restrict)

  code   String
  status TransferStatus @default(PENDING)
  note   String?

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  items TransferItem[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([status])
  @@map("transfers")
}

model TransferItem {
  id         String   @id @default(uuid()) @db.Uuid
  transferId String   @db.Uuid
  transfer   Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productId  String   @db.Uuid
  product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  quantity Decimal  @db.Decimal(18, 3)
  /// Average Cost của Kho nguồn tại thời điểm Approve — mang theo sang Kho đích khi Receive.
  unitCost Decimal? @db.Decimal(18, 2)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([transferId])
  @@index([productId])
  @@map("transfer_items")
}

enum StockCountStatus {
  DRAFT
  COUNTING
  COMPLETED
  CANCELLED
}

model StockCount {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  warehouseId    String       @db.Uuid
  warehouse      Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  code   String
  status StockCountStatus @default(DRAFT)
  note   String?

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  items StockCountItem[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([warehouseId])
  @@index([status])
  @@map("stock_counts")
}

model StockCountItem {
  id           String     @id @default(uuid()) @db.Uuid
  stockCountId String     @db.Uuid
  stockCount   StockCount @relation(fields: [stockCountId], references: [id], onDelete: Cascade)
  productId    String     @db.Uuid
  product      Product    @relation(fields: [productId], references: [id], onDelete: Restrict)

  /// Tồn kho hệ thống — chụp tại thời điểm tạo phiếu kiểm kê.
  systemQty  Decimal  @db.Decimal(18, 3)
  /// Số lượng đếm thực tế — chỉ có giá trị sau khi Complete.
  actualQty  Decimal? @db.Decimal(18, 3)
  /// = actualQty - systemQty, tính khi Complete.
  difference Decimal? @db.Decimal(18, 3)
  remark     String?

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([stockCountId, productId])
  @@index([stockCountId])
  @@index([productId])
  @@map("stock_count_items")
}

enum InventoryAdjustmentStatus {
  DRAFT
  SUBMITTED
  APPROVED
  COMPLETED
}

enum InventoryAdjustmentReason {
  LOST
  DAMAGED
  FOUND
  SYSTEM
  OTHER
}

model InventoryAdjustment {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  warehouseId    String       @db.Uuid
  warehouse      Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  code   String
  status InventoryAdjustmentStatus @default(DRAFT)
  reason InventoryAdjustmentReason
  note   String?

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  items InventoryAdjustmentItem[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([warehouseId])
  @@index([status])
  @@map("inventory_adjustments")
}

model InventoryAdjustmentItem {
  id           String              @id @default(uuid()) @db.Uuid
  adjustmentId String              @db.Uuid
  adjustment   InventoryAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  productId    String              @db.Uuid
  product      Product             @relation(fields: [productId], references: [id], onDelete: Restrict)

  /// Delta có dấu do người tạo nhập (dương = tăng tồn kho, âm = giảm).
  quantity Decimal @db.Decimal(18, 3)
  remark   String?

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([adjustmentId, productId])
  @@index([adjustmentId])
  @@index([productId])
  @@map("inventory_adjustment_items")
}

// =========================================================================
// SALES
// =========================================================================

model Order {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branchId       String       @db.Uuid
  branch         Branch       @relation(fields: [branchId], references: [id], onDelete: Restrict)
  warehouseId    String       @db.Uuid
  warehouse      Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  customerId     String?      @db.Uuid
  customer       Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  soldBy         String?      @db.Uuid
  soldByUser     User?        @relation("OrderSoldBy", fields: [soldBy], references: [id], onDelete: SetNull)

  code           String
  type           OrderType   @default(POS)
  status         OrderStatus @default(PENDING)
  subTotal       Decimal     @db.Decimal(18, 2)
  discountAmount Decimal     @default(0) @db.Decimal(18, 2)
  taxAmount      Decimal     @default(0) @db.Decimal(18, 2)
  shippingFee    Decimal     @default(0) @db.Decimal(18, 2)
  totalAmount    Decimal     @db.Decimal(18, 2)
  note           String?

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  orderItems OrderItem[]
  invoices   Invoice[]
  returns    Return[]
  delivery   Delivery?

  @@unique([organizationId, code])
  @@index([organizationId, branchId, createdAt])
  @@index([customerId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid()) @db.Uuid
  orderId   String  @db.Uuid
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  quantity    Decimal @db.Decimal(18, 3)
  unitPrice   Decimal @db.Decimal(18, 2)
  discount    Decimal @default(0) @db.Decimal(18, 2)
  taxAmount   Decimal @default(0) @db.Decimal(18, 2)
  totalAmount Decimal @db.Decimal(18, 2)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  returnItems ReturnItem[]

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

/**
 * `orderId` optional (Prompt 035): Order Module chưa xây (quy hoạch Volume 036-040) — Checkout
 * Engine tạo Invoice trực tiếp từ Cart, không qua Order. Giữ field + quan hệ để Order Module
 * sau này có thể gắn ngược vào Invoice đã có mà KHÔNG cần đổi schema lần nữa (không rewrite).
 * `customerId` optional vì Cart Engine (Prompt 033) không bắt buộc khách hàng.
 */
model Invoice {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branchId       String       @db.Uuid
  branch         Branch       @relation(fields: [branchId], references: [id], onDelete: Restrict)
  orderId        String?      @db.Uuid
  order          Order?       @relation(fields: [orderId], references: [id], onDelete: SetNull)
  customerId     String?      @db.Uuid
  customer       Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)

  code        String
  status      InvoiceStatus @default(UNPAID)
  totalAmount Decimal       @db.Decimal(18, 2)
  paidAmount  Decimal       @default(0) @db.Decimal(18, 2)
  dueAmount   Decimal       @default(0) @db.Decimal(18, 2)
  dueDate     DateTime?

  createdBy String?  @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items    InvoiceItem[]
  payments Payment[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([orderId])
  @@index([customerId])
  @@index([status])
  @@map("invoices")
}

/// Dòng chi tiết hóa đơn — snapshot tại thời điểm Checkout, không đổi sau khi tạo (Prompt 035).
model InvoiceItem {
  id        String  @id @default(uuid()) @db.Uuid
  invoiceId String  @db.Uuid
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  quantity    Decimal @db.Decimal(18, 3)
  unitPrice   Decimal @db.Decimal(18, 2)
  discount    Decimal @default(0) @db.Decimal(18, 2)
  taxAmount   Decimal @default(0) @db.Decimal(18, 2)
  totalAmount Decimal @db.Decimal(18, 2)

  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@index([productId])
  @@map("invoice_items")
}

model Return {
  id              String       @id @default(uuid()) @db.Uuid
  organizationId  String       @db.Uuid
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  orderId         String       @db.Uuid
  order           Order        @relation(fields: [orderId], references: [id], onDelete: Restrict)
  processedBy     String?      @db.Uuid
  processedByUser User?        @relation("ReturnProcessedBy", fields: [processedBy], references: [id], onDelete: SetNull)

  code        String
  reason      String?
  status      ReturnStatus @default(PENDING)
  totalRefund Decimal      @db.Decimal(18, 2)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  returnItems ReturnItem[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([orderId])
  @@index([status])
  @@map("returns")
}

model ReturnItem {
  id          String    @id @default(uuid()) @db.Uuid
  returnId    String    @db.Uuid
  return      Return    @relation(fields: [returnId], references: [id], onDelete: Cascade)
  orderItemId String    @db.Uuid
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Restrict)
  productId   String    @db.Uuid
  product     Product   @relation(fields: [productId], references: [id], onDelete: Restrict)

  quantity     Decimal @db.Decimal(18, 3)
  refundAmount Decimal @db.Decimal(18, 2)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([returnId])
  @@index([productId])
  @@map("return_items")
}

// =========================================================================
// CUSTOMER RELATIONSHIP
// =========================================================================

model CustomerGroup {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  name         String
  discountRate Decimal @default(0) @db.Decimal(5, 2)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([organizationId])
  @@map("customer_groups")
}

model Customer {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  code         String
  customerType CustomerType @default(RETAIL)
  fullName     String
  phone        String
  email        String?
  birthday     DateTime?
  gender       Gender?
  /// Chỉ có ý nghĩa với customerType DEALER/COMPANY — không bắt buộc ở tầng schema.
  taxCode      String?
  companyName  String?
  address      String?
  province     String?
  district     String?
  ward         String?
  avatar       String?
  note         String?
  creditLimit  Decimal?     @db.Decimal(18, 2)
  /// Do hệ thống duy trì (Customer Debt — Prompt tương lai), không cho client sửa trực tiếp.
  currentDebt  Decimal      @default(0) @db.Decimal(18, 2)
  /// Do hệ thống duy trì (Order module — Volume 11), không cho client sửa trực tiếp.
  totalRevenue Decimal      @default(0) @db.Decimal(18, 2)
  totalOrder   Int          @default(0)
  /// Do hệ thống duy trì (Customer Point Ledger — Prompt 032), không cho client sửa trực tiếp.
  totalPoint   Int          @default(0)
  status       CommonStatus @default(ACTIVE)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  orders       Order[]
  debts        Debt[]
  pointLedgers CustomerPointLedger[]
  payments     Payment[]
  invoices     Invoice[]

  @@unique([organizationId, code])
  @@unique([organizationId, phone])
  @@index([organizationId])
  @@index([fullName])
  @@map("customers")
}

model Debt {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  customerId     String?      @db.Uuid
  customer       Customer?    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  supplierId     String?      @db.Uuid
  supplier       Supplier?    @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  type       DebtType
  refType    String?
  refId      String?    @db.Uuid
  amount     Decimal    @db.Decimal(18, 2)
  paidAmount Decimal    @default(0) @db.Decimal(18, 2)
  dueDate    DateTime?
  status     DebtStatus @default(OPEN)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([organizationId])
  @@index([customerId])
  @@index([supplierId])
  @@index([organizationId, status, dueDate])
  @@map("debts")
}

/// Sổ cái điểm thưởng ghi-thêm (append-only) — nguồn sự thật duy nhất cho điểm của Customer
/// (Prompt 032). Không có updatedAt/deletedAt: một dòng không bao giờ được sửa/xóa, cùng
/// triết lý InventoryMovement (Prompt 022). Customer.totalPoint chỉ là cache đọc nhanh,
/// được đồng bộ qua Domain Event (PointAdded/PointUsed/PointExpired), không phải nguồn sự thật.
model CustomerPointLedger {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  customerId     String       @db.Uuid
  customer       Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  /// Nguồn phát sinh dòng điểm này (vd: "ORDER", "MANUAL", "PROMOTION") — tự do, không FK.
  referenceType String?
  referenceId   String?   @db.Uuid
  /// Delta có dấu: dương = cộng điểm (add), âm = trừ điểm (use).
  point         Int
  /// Số dư tích lũy NGAY SAU dòng này — snapshot bất biến, không tính lại từ đầu mỗi lần đọc.
  balance       Int
  expiredAt     DateTime?

  createdBy String?  @db.Uuid
  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([customerId, createdAt])
  @@map("customer_point_ledgers")
}

// =========================================================================
// FINANCE
// =========================================================================

model Payment {
  id              String         @id @default(uuid()) @db.Uuid
  organizationId  String         @db.Uuid
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branchId        String         @db.Uuid
  branch          Branch         @relation(fields: [branchId], references: [id], onDelete: Restrict)
  invoiceId       String?        @db.Uuid
  invoice         Invoice?       @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  purchaseOrderId String?        @db.Uuid
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  customerId      String?        @db.Uuid
  customer        Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  supplierId      String?        @db.Uuid
  supplier        Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  receivedBy      String?        @db.Uuid
  receivedByUser  User?          @relation("PaymentReceivedBy", fields: [receivedBy], references: [id], onDelete: SetNull)

  method    PaymentMethod
  direction PaymentDirection
  amount    Decimal          @db.Decimal(18, 2)
  paidAt    DateTime

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([organizationId])
  @@index([invoiceId])
  @@index([purchaseOrderId])
  @@index([direction])
  @@map("payments")
}

model CashBook {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branchId       String       @db.Uuid
  branch         Branch       @relation(fields: [branchId], references: [id], onDelete: Restrict)

  code         String
  type         CashBookType
  category     String?
  amount       Decimal      @db.Decimal(18, 2)
  balanceAfter Decimal      @db.Decimal(18, 2)
  refType      String?
  refId        String?      @db.Uuid
  note         String?

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([organizationId, code])
  @@index([organizationId, branchId])
  @@index([type])
  @@map("cash_books")
}

model ExpenseCategory {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  name String

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  expenses Expense[]

  @@index([organizationId])
  @@map("expense_categories")
}

model Expense {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @db.Uuid
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branchId       String           @db.Uuid
  branch         Branch           @relation(fields: [branchId], references: [id], onDelete: Restrict)
  categoryId     String?          @db.Uuid
  category       ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  code        String
  amount      Decimal  @db.Decimal(18, 2)
  description String?
  paidAt      DateTime

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([organizationId, code])
  @@index([organizationId, branchId])
  @@map("expenses")
}

// =========================================================================
// MARKETING
// =========================================================================

model Promotion {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branchId       String?      @db.Uuid
  branch         Branch?      @relation(fields: [branchId], references: [id], onDelete: Cascade)

  code       String
  name       String
  type       PromotionType
  value      Decimal         @db.Decimal(18, 2)
  applyScope ApplyScope
  startDate  DateTime
  endDate    DateTime
  status     PromotionStatus @default(ACTIVE)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  conditions PromotionCondition[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([startDate, endDate])
  @@map("promotions")
}

model PromotionCondition {
  id          String    @id @default(uuid()) @db.Uuid
  promotionId String    @db.Uuid
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  conditionType PromotionConditionType
  targetId      String?                @db.Uuid
  minQuantity   Int?
  minAmount     Decimal?               @db.Decimal(18, 2)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([promotionId])
  @@map("promotion_conditions")
}

model Voucher {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  code           String
  type           VoucherType
  value          Decimal       @db.Decimal(18, 2)
  minOrderAmount Decimal?      @db.Decimal(18, 2)
  maxDiscount    Decimal?      @db.Decimal(18, 2)
  usageLimit     Int?
  usedCount      Int           @default(0)
  startDate      DateTime
  endDate        DateTime
  status         VoucherStatus @default(ACTIVE)

  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("vouchers")
}

// =========================================================================
// FULFILLMENT
